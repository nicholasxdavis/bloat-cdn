# Point the SIYF engine at bloat-cdn (local static server on published/)
SIYF_CDN_URL=http://localhost:8787
VITE_SIYF_CDN_URL=http://localhost:8787

# Production — jsDelivr CDN root (published/ folder)
# SIYF_CDN_URL=https://cdn.jsdelivr.net/gh/nicholasxdavis/bloat-cdn@main/published
# VITE_SIYF_CDN_URL=https://cdn.jsdelivr.net/gh/nicholasxdavis/bloat-cdn@main/published

# HTTP rate limit (ms between requests)
BLOAT_DELAY_MS=400

# Retries for transient ESPN / CDN failures (429, 5xx, timeouts)
BLOAT_FETCH_RETRIES=4
BLOAT_RETRY_DELAY_MS=2000
BLOAT_FETCH_TIMEOUT_MS=45000

# Force nightly sync for off-season sports (comma-separated sport ids)
# BLOAT_FORCE_SPORTS=nba,nfl
